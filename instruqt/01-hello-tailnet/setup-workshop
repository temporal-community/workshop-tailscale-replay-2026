#!/bin/bash
set -euxo pipefail

# ============================================================
# Challenge 1 Setup: Install tooling, clone repo, configure env
# This runs once and sets up state for all subsequent challenges.
# ============================================================

REPO_URL="https://github.com/temporal-community/workshop-tailscale-replay-2026.git"
WORKSHOP_DIR="/root/workshop"

# --- Install system dependencies ---

# Python 3.13 via deadsnakes PPA
apt-get update -qq
apt-get install -y -qq software-properties-common
add-apt-repository -y ppa:deadsnakes/ppa
apt-get update -qq
apt-get install -y -qq python3.13 python3.13-venv python3.13-dev

# uv (Python package manager)
curl -LsSf https://astral.sh/uv/install.sh | sh
export PATH="$HOME/.local/bin:$PATH"

# Go
GO_VERSION="1.22.5"
curl -LsSf "https://go.dev/dl/go${GO_VERSION}.linux-amd64.tar.gz" | tar -C /usr/local -xzf -
export PATH="/usr/local/go/bin:$PATH"

# Temporal CLI
curl -sSf https://temporal.download/cli.sh | sh
export PATH="$HOME/.temporalio/bin:$PATH"

# --- Connect to Tailscale ---

curl -fsSL https://tailscale.com/install.sh | sh
# tailscale up --authkey="${TS_AUTHKEY}" --hostname="workshop-$(hostname)"

# Wait for Tailscale to be ready
sleep 3
tailscale status

# --- Clone workshop repo ---

if [ ! -d "$WORKSHOP_DIR" ]; then
    git clone "$REPO_URL" "$WORKSHOP_DIR"
fi

cd "$WORKSHOP_DIR"

# --- Set up environment variables ---

WORKSHOP_USER_ID=$(hostname | tr '[:upper:]' '[:lower:]')

cat >> /root/.bashrc << EOF

# Workshop environment variables
export PATH="\$HOME/.local/bin:/usr/local/go/bin:\$HOME/.temporalio/bin:\$PATH"
export TEMPORAL_PROFILE=tailnet
export WORKSHOP_USER_ID=${WORKSHOP_USER_ID}
# TODO: Update with actual Aperture endpoint from Kartik
export OPENAI_BASE_URL=https://aperture.tailnet-name.ts.net/v1
export OPENAI_API_KEY=workshop-token
EOF

# Source them for this script too
export TEMPORAL_PROFILE=tailnet
export WORKSHOP_USER_ID="${WORKSHOP_USER_ID}"

# --- Create Temporal environment config ---
# Note: We create the default profile only. The tailnet profile is the
# exercise TODO — attendees will copy temporal.toml.example themselves.

mkdir -p /root/.config/temporalio

# --- Install Python dependencies ---

cd "$WORKSHOP_DIR"
uv sync

echo "==> Setup complete. User ID: ${WORKSHOP_USER_ID}"
