#!/bin/bash
set -euxo pipefail

export PATH="/usr/local/go/bin:$PATH"

# Discard any working-tree modifications from the previous challenge
# so dirty files don't survive into this one. `git sparse-checkout set`
# refuses to silently drop modified files; without this reset, the
# attendee's Code Editor tree would carry orphan leftovers (e.g.
# their edited practice/worker.py from ex1).
cd /root/workshop
git reset --hard HEAD

# Narrow the sparse-checkout to only exercise 2, so the Code Editor
# tree at /root/workshop isn't cluttered with code from earlier
# exercises the attendee has already moved past.
git sparse-checkout set --no-cone \
    '/pyproject.toml' \
    '/uv.lock' \
    '/temporal.toml' \
    '/exercises/02_explore_tailscale/**'

# The Go module cache and build cache for tsnet should already be
# warm from the background job kicked off in ex1's setup-workshop.
# If the attendee somehow raced past ex1 faster than the warmup
# finished, `go mod download` here is cheap insurance.
cd /root/workshop/exercises/02_explore_tailscale/go-hello-tsnet/practice
go mod download
