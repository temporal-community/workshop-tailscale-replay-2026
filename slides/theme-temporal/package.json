{
  "name": "slidev-theme-temporal",
  "version": "0.1.0",
  "description": "Slidev theme matching Temporal's brand — Inter ExtraLight/Light, mint+purple palette, grid + starfield backgrounds.",
  "keywords": ["slidev-theme", "slidev", "temporal"],
  "private": true,
  "engines": {
    "slidev": ">=52.0.0"
  },
  "slidev": {
    "defaults": {
      "aspectRatio": "16/9",
      "canvasWidth": 980,
      "fonts": {
        "sans": "Inter",
        "mono": "Noto Sans Mono",
        "weights": "200,300,400,500,600",
        "italic": false
      }
    },
    "colorSchema": "dark",
    "highlighter": "shiki"
  }
}
