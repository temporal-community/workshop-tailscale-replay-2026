#!/bin/bash
set -euxo pipefail

# Discard any working-tree modifications from the previous challenge
# so dirty files don't survive into this one. `git sparse-checkout set`
# refuses to silently drop modified files; without this reset, the
# attendee's Code Editor tree would carry orphan leftovers (e.g.
# their edited practice/main.go from ex2).
cd /root/workshop
git reset --hard HEAD

# Narrow the sparse-checkout to only exercise 3, so the Code Editor
# tree at /root/workshop isn't cluttered with code from earlier
# exercises the attendee has already moved past.
git sparse-checkout set --no-cone \
    '/pyproject.toml' \
    '/uv.lock' \
    '/temporal.toml' \
    '/exercises/03_weather_agent/**'
