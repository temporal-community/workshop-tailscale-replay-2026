# Temporal environment configuration
# See temporal.toml.example for profile definitions
TEMPORAL_PROFILE=tailnet

# Aperture proxy endpoint for OpenAI (routes through Tailscale)
OPENAI_BASE_URL=https://aperture.tailnet-name.ts.net/v1

# Aperture handles auth to OpenAI — this token identifies you to Aperture
OPENAI_API_KEY=<set-by-instruqt-or-instructor>

# Your unique workshop identifier (set automatically by Instruqt)
WORKSHOP_USER_ID=<your-hostname-or-id>
