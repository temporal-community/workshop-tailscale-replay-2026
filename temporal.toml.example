# Temporal Environment Configuration
# Documentation: https://docs.temporal.io/develop/environment-configuration
#
# Copy this file to ~/.config/temporalio/temporal.toml
# Then set TEMPORAL_PROFILE in your .env to choose which profile to use.

# Default profile — local development (Temporal server on your machine)
[profile.default]
address = "localhost:7233"
namespace = "default"

# Workshop tailnet (shared Temporal server via Tailscale)
[profile.tailnet]
address = "temporal-dev:7233"
namespace = "default"
